<Window x:Class="Medital_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Medical Billing ERP"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#B3E5FC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="8,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SideSection" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="20,16,0,4"/>
            <Setter Property="CharacterSpacing" Value="120"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" x:Name="ColSidebar"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
        <Border Grid.Column="0" Background="#0D1B2A">
            <DockPanel>
                <!-- Logo / Company -->
                <Border DockPanel.Dock="Top" Background="#071628" Padding="0,20,0,16">
                    <StackPanel>
                        <Ellipse Width="52" Height="52" Fill="#1565C0" HorizontalAlignment="Center">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#1565C0" BlurRadius="15" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="+" FontSize="28" Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,-40,0,0" FontWeight="Light"/>
                        <TextBlock Text="{Binding CompanyName}" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,2"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding FinancialYear, StringFormat='FY {0}'}"
                                   FontSize="11" Foreground="#90A4AE" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="MAIN" Style="{StaticResource SideSection}"/>
                        <Button Content="📊  Dashboard"      Command="{Binding NavigateDashboardCommand}" Style="{StaticResource SidebarBtn}"/>
                        <Button Content="🛒  New Sale"       Command="{Binding NavigateSaleCommand}"      Style="{StaticResource SidebarBtn}"/>
                        <Button Content="📋  Sale List"      Command="{Binding NavigateSaleListCommand}"  Style="{StaticResource SidebarBtn}"/>
                        <Button Content="📦  New Purchase"   Command="{Binding NavigatePurchaseCommand}"  Style="{StaticResource SidebarBtn}"/>
                        <Button Content="📃  Purchase List"  Command="{Binding NavigatePurchaseListCommand}" Style="{StaticResource SidebarBtn}"/>

                        <TextBlock Text="INVENTORY" Style="{StaticResource SideSection}"/>
                        <Button Content="🏪  Stock"          Command="{Binding NavigateStockCommand}"     Style="{StaticResource SidebarBtn}"/>

                        <TextBlock Text="ACCOUNTS" Style="{StaticResource SideSection}"/>
                        <Button Content="👥  Accounts"       Command="{Binding NavigateAccountsCommand}"  Style="{StaticResource SidebarBtn}"/>
                        <Button Content="💰  Receipt"        Command="{Binding NavigateReceiptCommand}"   Style="{StaticResource SidebarBtn}"/>
                        <Button Content="💸  Payment"        Command="{Binding NavigatePaymentCommand}"   Style="{StaticResource SidebarBtn}"/>

                        <TextBlock Text="REPORTS" Style="{StaticResource SideSection}"/>
                        <Button Content="📈  Reports"        Command="{Binding NavigateReportsCommand}"   Style="{StaticResource SidebarBtn}"/>
                        <Button Content="🧾  GST Report"     Command="{Binding NavigateGSTCommand}"       Style="{StaticResource SidebarBtn}"/>

                        <TextBlock Text="ADMIN" Style="{StaticResource SideSection}"/>
                        <Button Content="⚙️  Settings"       Command="{Binding NavigateSettingsCommand}"  Style="{StaticResource SidebarBtn}"/>
                        <Button Content="💾  Backup Now"     Command="{Binding BackupNowCommand}"         Style="{StaticResource SidebarBtn}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- User info at bottom -->
                <Border DockPanel.Dock="Bottom" Background="#071628" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="32" Height="32" Fill="#1565C0">
                            <Ellipse.ToolTip>
                                <ToolTip Content="{Binding UserName}"/>
                            </Ellipse.ToolTip>
                        </Ellipse>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="{Binding UserName}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentDate}" Foreground="#78909C" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════ CONTENT AREA ═══════════════════════════ -->
        <Grid Grid.Column="1" Background="#F5F7FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="{Binding CurrentModuleName}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#1A237E" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentDate}" Foreground="#546E7A"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock Text="{Binding UserName}" Foreground="#37474F"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content view -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"
                            Margin="0"/>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="#1565C0" Padding="12,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>
