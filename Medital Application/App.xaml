<Application x:Class="Medital_Application.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Medital_Application"
             xmlns:helpers="clr-namespace:Medital_Application.Helpers">
    <Application.Resources>
        <helpers:NullToVisibilityConverter  x:Key="NullToVisibility"/>
        <helpers:LoadingTextConverter       x:Key="LoadingTextConverter"/>
        <helpers:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
    </Application.Resources>
</Application>
