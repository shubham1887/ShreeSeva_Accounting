<UserControl x:Class="Medital_Application.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F7FA">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A237E"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                       Foreground="#1A237E" Margin="0,0,0,20"/>

            <!-- Company Info -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Company Information" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Company Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.CompanyName}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="GSTIN" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.GSTIN}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Drug License No" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.DrugLicense}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="PAN" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.PAN}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.Address1}" Height="60"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.Phone}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="2">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.Email}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Financial Year -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Financial Settings" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Financial Year" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.FinancialYear}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="State Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.StateCode}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Bank Details -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Bank Details" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bank Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.BankName}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Account No" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.BankAccountNo}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="IFSC Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldBox}" Text="{Binding Company.IFSCCode}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="#388E3C" FontSize="12" Margin="0,0,0,8"/>

            <!-- Save Button -->
            <StackPanel HorizontalAlignment="Right" Margin="0,0,0,24">
                <Button Content="Save Settings" Width="160" Height="38"
                        Background="#1565C0" Foreground="White"
                        FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SaveAsyncCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
