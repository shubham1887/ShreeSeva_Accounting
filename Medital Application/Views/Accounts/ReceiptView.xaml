<UserControl x:Class="Medital_Application.Views.Accounts.ReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#F5F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Receipt Voucher" FontSize="20" FontWeight="Bold"
                   Foreground="#1A237E" Margin="0,0,0,16"/>

        <!-- Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Voucher No" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <TextBox Height="34" Padding="8,6" FontSize="13" BorderBrush="#CFD8DC" BorderThickness="1"
                             IsReadOnly="True" Background="#F5F7FA"
                             Text="{Binding VoucherNo, Mode=OneWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Date" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <DatePicker Height="34" FontSize="13" SelectedDate="{Binding VoucherDate}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Customer / Party" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <ComboBox Height="34" FontSize="13"
                              ItemsSource="{Binding Customers}"
                              DisplayMemberPath="AccountName"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedCustomerId}"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="Amount (Rs.)" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <TextBox Height="34" Padding="8,6" FontSize="13" BorderBrush="#CFD8DC" BorderThickness="1"
                             TextAlignment="Right"
                             Text="{Binding Amount, StringFormat='N2', UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Payment Mode & Narration -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Payment Mode" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <ComboBox Height="34" FontSize="13" SelectedItem="{Binding SelectedPaymentMode}">
                        <ComboBoxItem>Cash</ComboBoxItem>
                        <ComboBoxItem>Cheque</ComboBoxItem>
                        <ComboBoxItem>NEFT</ComboBoxItem>
                        <ComboBoxItem>UPI</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Cheque / Ref No" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <TextBox Height="34" Padding="8,6" FontSize="13" BorderBrush="#CFD8DC" BorderThickness="1"
                             Text="{Binding ChequeNo}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4">
                    <TextBlock Text="Cheque Date" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <DatePicker Height="34" FontSize="13" SelectedDate="{Binding ChequeDate}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                    <TextBlock Text="Narration" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                    <TextBox Height="60" Padding="8,6" FontSize="13" BorderBrush="#CFD8DC" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Text="{Binding Narration}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status & Actions -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#546E7A" FontSize="12" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Clear (Esc)" Height="36" Padding="20,0" FontSize="13" FontWeight="SemiBold"
                        Background="#F5F5F5" Foreground="#37474F" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ClearAsyncCommand}" Margin="0,0,12,0"/>
                <Button Content="Save Receipt (F10)" Height="36" Padding="20,0" FontSize="13" FontWeight="SemiBold"
                        Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Command="{Binding SaveAsyncCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
