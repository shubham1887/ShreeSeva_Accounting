<UserControl x:Class="Medital_Application.Views.Sales.CounterSaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F0F2F5">

    <UserControl.Resources>
        <!-- Bill slot button -->
        <Style x:Key="SlotBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active slot -->
        <Style x:Key="SlotBtnActive" TargetType="Button" BasedOn="{StaticResource SlotBtn}">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#1565C0"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Payment mode toggle -->
        <Style x:Key="PayToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Bill slots -->
            <RowDefinition Height="Auto"/>   <!-- Search bar -->
            <RowDefinition Height="*"/>      <!-- Items grid -->
            <RowDefinition Height="Auto"/>   <!-- Totals + actions -->
        </Grid.RowDefinitions>

        <!-- ═══ BILL SLOTS ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Slot 1 -->
            <Button Grid.Column="0" Style="{StaticResource SlotBtnActive}" Margin="0,0,6,0"
                    Command="{Binding SwitchSlotCommand}" CommandParameter="1" Height="70">
                <StackPanel Margin="12,8">
                    <TextBlock Text="BILL 1" FontSize="11" FontWeight="Bold" Foreground="#1565C0"/>
                    <TextBlock Text="{Binding Slot1Badge}" FontSize="11" Foreground="#546E7A" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <!-- Slot 2 -->
            <Button Grid.Column="1" Style="{StaticResource SlotBtn}" Margin="3,0"
                    Command="{Binding SwitchSlotCommand}" CommandParameter="2" Height="70">
                <StackPanel Margin="12,8">
                    <TextBlock Text="BILL 2" FontSize="11" FontWeight="Bold" Foreground="#546E7A"/>
                    <TextBlock Text="{Binding Slot2Badge}" FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <!-- Slot 3 -->
            <Button Grid.Column="2" Style="{StaticResource SlotBtn}" Margin="3,0"
                    Command="{Binding SwitchSlotCommand}" CommandParameter="3" Height="70">
                <StackPanel Margin="12,8">
                    <TextBlock Text="BILL 3" FontSize="11" FontWeight="Bold" Foreground="#546E7A"/>
                    <TextBlock Text="{Binding Slot3Badge}" FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <!-- Slot 4 -->
            <Button Grid.Column="3" Style="{StaticResource SlotBtn}" Margin="3,0"
                    Command="{Binding SwitchSlotCommand}" CommandParameter="4" Height="70">
                <StackPanel Margin="12,8">
                    <TextBlock Text="BILL 4" FontSize="11" FontWeight="Bold" Foreground="#546E7A"/>
                    <TextBlock Text="{Binding Slot4Badge}" FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <!-- Slot 5 -->
            <Button Grid.Column="4" Style="{StaticResource SlotBtn}" Margin="3,0,6,0"
                    Command="{Binding SwitchSlotCommand}" CommandParameter="5" Height="70">
                <StackPanel Margin="12,8">
                    <TextBlock Text="BILL 5" FontSize="11" FontWeight="Bold" Foreground="#546E7A"/>
                    <TextBlock Text="{Binding Slot5Badge}" FontSize="11" Foreground="#90A4AE" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <!-- Date + info -->
            <Border Grid.Column="5" Background="White" CornerRadius="10" Padding="14,8"
                    BorderBrush="#CFD8DC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Date" FontSize="10" Foreground="#90A4AE"/>
                    <DatePicker SelectedDate="{Binding VoucherDate}" FontSize="12"
                                BorderThickness="0" Background="Transparent" Width="130"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ PRODUCT SEARCH ═══ -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="0,0,0,10"
                BorderBrush="#CFD8DC" BorderThickness="1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔍  Search Product (name / barcode)  [F2]"
                               FontSize="10" Foreground="#90A4AE" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtSearch"
                             Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="15" BorderThickness="0" Background="Transparent"
                             Padding="0,2"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding CustomerMobile}"
                           FontSize="13" Foreground="#546E7A" VerticalAlignment="Center"
                           Margin="16,0"/>

                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="12" Foreground="#E53935" VerticalAlignment="Center"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Product search results popup -->
        <Popup x:Name="SearchPopup" IsOpen="{Binding HasSearchResults}"
               PlacementTarget="{Binding ElementName=TxtSearch}"
               Placement="Bottom" StaysOpen="False" Width="500">
            <Border Background="White" BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <ListBox ItemsSource="{Binding ProductSearchResults}"
                         SelectedItem="{Binding SelectedProduct}"
                         MaxHeight="260" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ProductName}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HSNCode, StringFormat='HSN: \{0\}'}"
                                               FontSize="10" Foreground="#90A4AE"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding DefaultMRP, StringFormat='MRP ₹\{0:N0\}'}"
                                           FontSize="12" Foreground="#546E7A" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding DefaultSaleRate, StringFormat='Rate ₹\{0:N0\}'}"
                                           FontSize="12" Foreground="#1565C0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding CurrentQty, StringFormat='\{0\} qty'}"
                                           FontSize="12" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>

        <!-- ═══ ITEMS GRID ═══ -->
        <Border Grid.Row="2" Background="White" CornerRadius="10"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#FAFBFF"
                      RowBackground="White"
                      BorderThickness="0"
                      ColumnHeaderHeight="36"
                      RowHeight="38"
                      FontSize="13"
                      SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F7FA"/>
                        <Setter Property="Foreground" Value="#546E7A"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SrNo}" Width="40" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Batch" Binding="{Binding BatchNo}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryMY}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="MRP" Binding="{Binding Mrp, StringFormat='N2'}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Rate" Binding="{Binding SaleRate, StringFormat='N2'}" Width="80" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Disc%" Binding="{Binding ItemDiscPer, StringFormat='N1'}" Width="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="65">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Amount" Binding="{Binding LineTotal, StringFormat='N2'}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#1565C0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Background="Transparent" BorderThickness="0"
                                        Foreground="#EF5350" FontSize="14" Cursor="Hand"
                                        Command="{Binding DataContext.RemoveItemCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ═══ TOTALS + ACTIONS ═══ -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Payment mode + action buttons -->
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Payment Mode" FontSize="11" Foreground="#546E7A" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton Content="CASH" Style="{StaticResource PayToggle}"
                                 IsChecked="True" GroupName="PayMode" Margin="0,0,6,0"/>
                    <RadioButton Content="UPI" Style="{StaticResource PayToggle}"
                                 GroupName="PayMode" Margin="0,0,6,0"/>
                    <RadioButton Content="CARD" Style="{StaticResource PayToggle}"
                                 GroupName="PayMode" Margin="0,0,6,0"/>
                    <RadioButton Content="CREDIT" Style="{StaticResource PayToggle}"
                                 GroupName="PayMode"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="💾  Save  F10" Style="{StaticResource ActionBtn}"
                            Background="#1565C0" Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                    <Button Content="🖨  Print  F12" Style="{StaticResource ActionBtn}"
                            Background="#2E7D32" Command="{Binding PrintCommand}" Margin="0,0,8,0"/>
                    <Button Content="📱  WhatsApp" Style="{StaticResource ActionBtn}"
                            Background="#388E3C" Command="{Binding WhatsAppCommand}" Margin="0,0,8,0"/>
                    <Button Content="🗑  Clear  Esc" Style="{StaticResource ActionBtn}"
                            Background="#757575" Command="{Binding ClearCommand}"/>
                </StackPanel>

                <!-- Last bill info -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Last Bill: " FontSize="12" Foreground="#90A4AE"/>
                    <TextBlock Text="{Binding LastBillNo}" FontSize="12" Foreground="#546E7A" FontWeight="SemiBold"/>
                    <TextBlock Text="   Amt: ₹" FontSize="12" Foreground="#90A4AE"/>
                    <TextBlock Text="{Binding LastBillAmount, StringFormat='N2'}" FontSize="12"
                               Foreground="#1565C0" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <!-- Totals panel -->
            <Border Grid.Column="1" Background="White" CornerRadius="12"
                    BorderBrush="#E0E0E0" BorderThickness="1" Padding="20,14">
                <StackPanel>
                    <Grid Margin="0,3">
                        <TextBlock Text="Items" Foreground="#90A4AE" FontSize="13"/>
                        <TextBlock Text="{Binding Items.Count}" HorizontalAlignment="Right"
                                   FontSize="13" Foreground="#546E7A"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <TextBlock Text="Gross Amount" Foreground="#90A4AE" FontSize="13"/>
                        <TextBlock Text="{Binding GrossAmount, StringFormat='₹\{0:N2\}'}"
                                   HorizontalAlignment="Right" FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <TextBlock Text="Discount" Foreground="#90A4AE" FontSize="13"/>
                        <TextBlock Text="{Binding DiscountAmount, StringFormat='₹\{0:N2\}'}"
                                   HorizontalAlignment="Right" FontSize="13" Foreground="#E53935"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <TextBlock Text="GST" Foreground="#90A4AE" FontSize="13"/>
                        <TextBlock Text="{Binding TotalGST, StringFormat='₹\{0:N2\}'}"
                                   HorizontalAlignment="Right" FontSize="13"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,8"/>
                    <Grid>
                        <TextBlock Text="NET AMOUNT" FontSize="16" FontWeight="Bold" Foreground="#1A237E"/>
                        <TextBlock Text="{Binding NetAmount, StringFormat='₹\{0:N2\}'}"
                                   HorizontalAlignment="Right" FontSize="22" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
