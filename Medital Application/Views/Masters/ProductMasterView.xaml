<UserControl x:Class="Medital_Application.Views.Masters.ProductMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="#F5F7FA">

    <UserControl.Resources>
        <!-- Card border -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E0E0E0" BlurRadius="8" ShadowDepth="1" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form label -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>

        <!-- Form TextBox -->
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form ComboBox -->
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#90CAF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button (Delete) -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#EF9A9A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid row style -->
        <Style x:Key="GridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BBDEFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid header style -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Top Search / Action bar ──────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="12,12,12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="340" Padding="10,8" FontSize="13"
                             BorderBrush="#BDBDBD" BorderThickness="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </TextBox.Template>
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding LoadCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search" Margin="8,0,0,0"
                            Style="{StaticResource SecondaryBtn}"
                            Command="{Binding LoadCommand}"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Add New"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding NewProductCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="✏️ Edit"
                            Style="{StaticResource SecondaryBtn}"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding SelectedProduct, Converter={StaticResource NullToVisibility}, ConverterParameter=bool}"/>
                    <Button Content="🗑 Delete"
                            Style="{StaticResource DangerBtn}"
                            Command="{Binding DeleteCommand}"
                            CommandParameter="{Binding SelectedProduct}"
                            IsEnabled="{Binding SelectedProduct, Converter={StaticResource NullToVisibility}, ConverterParameter=bool}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main Split: Grid + Form ───────────────────────────────── -->
        <Grid Grid.Row="1" Margin="12,0,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Product DataGrid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Products" FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                        <Border Background="#E3F2FD" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                            <TextBlock Text="{Binding Products.Count}" FontSize="11"
                                       Foreground="#1565C0" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Loading indicator -->
                        <TextBlock Text=" Loading…" FontSize="12" Foreground="#1565C0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0"
                              RowStyle="{StaticResource GridRow}"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              Background="White"
                              AlternatingRowBackground="#FAFAFA">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name"
                                               Binding="{Binding ProductName}"
                                               Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Category"
                                               Binding="{Binding CategoryName}"
                                               Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Unit"
                                               Binding="{Binding Unit}"
                                               Width="60" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Pack"
                                               Binding="{Binding PackSize}"
                                               Width="55" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="MRP"
                                               Binding="{Binding DefaultMRP, StringFormat=N2}"
                                               Width="80" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Sale Rate"
                                               Binding="{Binding DefaultSaleRate, StringFormat=N2}"
                                               Width="80" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="GST%"
                                               Binding="{Binding SGSTRate, StringFormat=\{0:N0\}+\{0:N0\}}"
                                               Width="70" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Barcode"
                                               Binding="{Binding Barcode}"
                                               Width="110" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Stock"
                                               Binding="{Binding CurrentQty, StringFormat=N2}"
                                               Width="75" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Active checkbox -->
                            <DataGridTemplateColumn Header="Active" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDeleted, Converter={StaticResource BoolToVisibility}, Mode=OneWay}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  IsEnabled="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" Background="#E0E0E0"/>

            <!-- ── Right Form Panel ──────────────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Form header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Product Details" FontSize="14"
                                   FontWeight="Bold" Foreground="#1565C0"/>
                        <TextBlock Text=" (New)" FontSize="12" Foreground="#9E9E9E" VerticalAlignment="Bottom"
                                   Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibility}}"/>
                    </StackPanel>

                    <!-- Scroll area for form fields -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedProduct}">

                            <!-- Product Name -->
                            <TextBlock Text="Product Name *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormBox}"/>

                            <!-- Marathi Name -->
                            <TextBlock Text="Marathi Name" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding MarathiName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormBox}"/>

                            <!-- Unit + Pack -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Unit" Style="{StaticResource FormLabel}" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Pack Size" Style="{StaticResource FormLabel}" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding PackSize, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- HSN Code -->
                            <TextBlock Text="HSN Code" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding HSNCode, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormBox}"/>

                            <!-- GST Rates -->
                            <TextBlock Text="GST Rates (SGST / CGST / IGST %)"
                                       Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding SGSTRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                         Style="{StaticResource FormBox}"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding CGSTRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                         Style="{StaticResource FormBox}"/>
                                <TextBox Grid.Column="4"
                                         Text="{Binding IGSTRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                         Style="{StaticResource FormBox}"/>
                            </Grid>

                            <!-- Pricing -->
                            <TextBlock Text="MRP" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding DefaultMRP, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                     Style="{StaticResource FormBox}"/>

                            <TextBlock Text="Sale Rate" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding DefaultSaleRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                     Style="{StaticResource FormBox}"/>

                            <TextBlock Text="Purchase Rate" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding LastPurchaseRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                     Style="{StaticResource FormBox}"/>

                            <!-- Stock limits -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Min Stock" Style="{StaticResource FormLabel}" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding MinQty, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max Stock" Style="{StaticResource FormLabel}" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding MaxQty, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Barcode with generate button -->
                            <TextBlock Text="Barcode" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormBox}"
                                         FontFamily="Consolas"/>
                                <Button Grid.Column="1" Content="⚡ Gen"
                                        Style="{StaticResource SecondaryBtn}"
                                        Margin="6,0,0,0" Padding="10,6"
                                        Command="{Binding DataContext.GenerateBarcodeCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Grid>

                            <!-- Barcode preview (visible when Barcode is not empty) -->
                            <Border Margin="0,8,0,0" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="4" Height="60" Background="#FAFAFA"
                                    Visibility="{Binding Barcode, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="[Barcode image preview]"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#9E9E9E" FontSize="11" FontStyle="Italic"/>
                            </Border>

                            <!-- Flags -->
                            <Border Background="#F5F5F5" CornerRadius="4" Padding="10,8" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Flags" FontSize="11" FontWeight="Bold"
                                               Foreground="#546E7A" Margin="0,0,0,8"/>
                                    <CheckBox Content="  Scheduled Drug" IsChecked="{Binding IsScheduled}"
                                              FontSize="12" Margin="0,0,0,6"/>
                                    <CheckBox Content="  High Risk Drug" IsChecked="{Binding IsHighRisk}"
                                              FontSize="12" Margin="0,0,0,6"/>
                                    <CheckBox Content="  Non-Rx (OTC)" IsChecked="{Binding IsNonRx}"
                                              FontSize="12"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Form action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="💾 Save"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="✕ Cancel"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding NewProductCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="White" Margin="12,0,12,12"
                BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}"/>
        </Border>
    </Grid>
</UserControl>
