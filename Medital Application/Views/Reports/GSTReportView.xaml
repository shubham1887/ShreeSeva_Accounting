<UserControl x:Class="Medital_Application.Views.Reports.GSTReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="GST Report" FontSize="20" FontWeight="Bold"
                   Foreground="#1A237E" Margin="0,0,0,16"/>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#546E7A"/>
                <DatePicker Height="32" Width="130" FontSize="12" SelectedDate="{Binding FromDate}" Margin="0,0,16,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#546E7A"/>
                <DatePicker Height="32" Width="130" FontSize="12" SelectedDate="{Binding ToDate}" Margin="0,0,16,0"/>
                <Button Content="Generate GSTR-1" Width="130" Height="32" Background="#1565C0" Foreground="White"
                        FontSize="12" BorderThickness="0" Cursor="Hand"
                        Command="{Binding GenerateGSTRCommand}" Margin="0,0,12,0"/>
                <Button Content="Export CSV" Width="100" Height="32" Background="#388E3C" Foreground="White"
                        FontSize="12" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ExportCommand}"/>
            </StackPanel>
        </Border>

        <!-- Tabs: Bills + HSN Summary -->
        <TabControl Grid.Row="2">
            <TabItem Header="Bill-wise (B2B/B2C)">
                <DataGrid ItemsSource="{Binding GSTBills}" AutoGenerateColumns="False"
                          IsReadOnly="True" HeadersVisibility="Column" FontSize="12"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8F9FF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Voucher No" Binding="{Binding VoucherNo}" Width="120"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding VoucherDate, StringFormat='dd-MMM-yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Party" Binding="{Binding AccountName}" Width="*"/>
                        <DataGridTextColumn Header="GSTIN" Binding="{Binding GSTIN}" Width="160"/>
                        <DataGridTextColumn Header="Taxable" Binding="{Binding TaxableAmount, StringFormat='N2'}" Width="90">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SGST" Binding="{Binding SGSTAmount, StringFormat='N2'}" Width="80">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CGST" Binding="{Binding CGSTAmount, StringFormat='N2'}" Width="80">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="IGST" Binding="{Binding IGSTAmount, StringFormat='N2'}" Width="80">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Net" Binding="{Binding TotalAmount, StringFormat='N2'}" Width="90">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="SemiBold"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="HSN Summary">
                <DataGrid ItemsSource="{Binding HSNSummary}" AutoGenerateColumns="False"
                          IsReadOnly="True" HeadersVisibility="Column" FontSize="12"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8F9FF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="HSN Code" Binding="{Binding HSNCode}" Width="100"/>
                        <DataGridTextColumn Header="GST Rate %" Binding="{Binding GSTRate, StringFormat='N0'}" Width="90"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty}" Width="70">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Taxable" Binding="{Binding TaxableAmount, StringFormat='N2'}" Width="100">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SGST" Binding="{Binding SGSTAmount, StringFormat='N2'}" Width="90">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CGST" Binding="{Binding CGSTAmount, StringFormat='N2'}" Width="90">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="IGST" Binding="{Binding IGSTAmount, StringFormat='N2'}" Width="90">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total GST" Binding="{Binding TotalTax, StringFormat='N2'}" Width="100">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="SemiBold"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
