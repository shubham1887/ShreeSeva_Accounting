<UserControl x:Class="Medital_Application.Views.Reports.SalesReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F5F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sales Report" FontSize="20" FontWeight="Bold"
                   Foreground="#1A237E" Margin="0,0,0,16"/>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#546E7A"/>
                <DatePicker Height="32" Width="130" FontSize="12" SelectedDate="{Binding FromDate}" Margin="0,0,16,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#546E7A"/>
                <DatePicker Height="32" Width="130" FontSize="12" SelectedDate="{Binding ToDate}" Margin="0,0,16,0"/>
                <Button Content="Load" Width="80" Height="32" Background="#1565C0" Foreground="White"
                        FontSize="12" BorderThickness="0" Cursor="Hand"
                        Command="{Binding LoadAsyncCommand}" Margin="0,0,12,0"/>
                <Button Content="Export CSV" Width="100" Height="32" Background="#388E3C" Foreground="White"
                        FontSize="12" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ExportAsyncCommand}"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Sales}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8F9FF"
                      BorderThickness="0" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Voucher No" Binding="{Binding VoucherNo}" Width="120"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding VoucherDate, StringFormat='dd-MMM-yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Party" Binding="{Binding AccountName}" Width="*"/>
                    <DataGridTextColumn Header="Gross" Binding="{Binding GrossAmount, StringFormat='N2'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Discount" Binding="{Binding ItemDiscAmount, StringFormat='N2'}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="CGST" Binding="{Binding TotalCGST, StringFormat='N2'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SGST" Binding="{Binding TotalSGST, StringFormat='N2'}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Net Amount" Binding="{Binding NetAmount, StringFormat='N2'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right" FontWeight="SemiBold"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Mode" Binding="{Binding PaymentMode}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Totals -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="16,10" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Total Sales: " FontSize="13" Foreground="#546E7A" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalSales, StringFormat='Rs. N2'}" FontSize="14" FontWeight="Bold"
                           Foreground="#1A237E" VerticalAlignment="Center" Margin="4,0,24,0"/>
                <TextBlock Text="Total GST: " FontSize="13" Foreground="#546E7A" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalGST, StringFormat='Rs. N2'}" FontSize="14" FontWeight="Bold"
                           Foreground="#C62828" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
