<UserControl x:Class="Medital_Application.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Card style -->
        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#78909C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Summary Cards -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Today Sales -->
                <Border Grid.Column="0" Style="{StaticResource DashCard}" Background="White">
                    <StackPanel>
                        <TextBlock Text="TODAY SALES" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="{Binding TodaySales, StringFormat='₹{0:N0}'}"
                                   Style="{StaticResource CardValue}" Foreground="#1565C0"/>
                        <TextBlock Text="Cash + Credit" FontSize="11" Foreground="#90A4AE" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Today Purchase -->
                <Border Grid.Column="1" Style="{StaticResource DashCard}" Background="White">
                    <StackPanel>
                        <TextBlock Text="TODAY PURCHASE" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="{Binding TodayPurchase, StringFormat='₹{0:N0}'}"
                                   Style="{StaticResource CardValue}" Foreground="#FF6F00"/>
                        <TextBlock Text="From Distributors" FontSize="11" Foreground="#90A4AE" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Pending Recovery -->
                <Border Grid.Column="2" Style="{StaticResource DashCard}" Background="White">
                    <StackPanel>
                        <TextBlock Text="PENDING RECOVERY" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="{Binding PendingRecovery, StringFormat='₹{0:N0}'}"
                                   Style="{StaticResource CardValue}" Foreground="#E53935"/>
                        <TextBlock Text="Outstanding from Customers" FontSize="11" Foreground="#90A4AE" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="3" Style="{StaticResource DashCard}" Background="White">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ITEMS" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="{Binding LowStockCount}"
                                   Style="{StaticResource CardValue}" Foreground="#F57F17"/>
                        <TextBlock Text="{Binding ExpiringCount, StringFormat='{0} expiring soon'}"
                                   FontSize="11" Foreground="#90A4AE" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Two-column layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Transactions -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="8"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Recent Transactions" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1A237E" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding RecentTransactions}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" BorderThickness="0"
                                  RowBackground="White" AlternatingRowBackground="#F9FAFB"
                                  HeadersVisibility="Column" ColumnHeaderHeight="36">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Voucher" Binding="{Binding VoucherNo}" Width="120"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd-MMM'}" Width="80"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                                <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₹{0:N2}'}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#1565C0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Alerts -->
                <StackPanel Grid.Column="1">
                    <!-- Low Stock -->
                    <Border Background="White" CornerRadius="12" Margin="8,8,8,4" Padding="16">
                        <StackPanel>
                            <TextBlock Text="⚠ Low Stock" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#F57F17" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding LowStockItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF8E1" CornerRadius="6" Margin="0,2"
                                                Padding="10,6">
                                            <Grid>
                                                <TextBlock Text="{Binding ProductName}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#E65100" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                                <TextBlock Text="{Binding CurrentQty, StringFormat='{0} left'}"
                                                           HorizontalAlignment="Right" FontSize="11" Foreground="#BF360C"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Expiring -->
                    <Border Background="White" CornerRadius="12" Margin="8,4,8,8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="⏰ Expiring Soon" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#E53935" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding ExpiringItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFEBEE" CornerRadius="6" Margin="0,2"
                                                Padding="10,6">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ProductName}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#C62828" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                                    <TextBlock Text="{Binding ExpiryMY, StringFormat='Exp: {0}'}"
                                                               FontSize="10" Foreground="#B71C1C"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding CurrentQty, StringFormat='{0} qty'}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="11" Foreground="#C62828"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Quick Actions -->
            <Border Background="White" CornerRadius="12" Margin="8,0,8,8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold"
                               Foreground="#1A237E" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <Button Content="+ New Sale" Background="#1565C0" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="+ New Purchase" Background="#FF6F00" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Receipt" Background="#2E7D32" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Payment" Background="#6A1B9A" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Stock Report" Background="#37474F" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
