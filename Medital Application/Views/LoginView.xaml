<Window x:Class="Medital_Application.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Login – Medical ERP"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1B2A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Ellipse Width="72" Height="72" Fill="#1565C0" HorizontalAlignment="Center">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#1565C0" BlurRadius="20" ShadowDepth="0"/>
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock Text="+" FontSize="36" Foreground="White" HorizontalAlignment="Center"
                       Margin="0,-52,0,0" FontWeight="Light"/>
            <TextBlock Text="{Binding CompanyName}" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock Text="Medical Billing ERP" FontSize="12" Foreground="#90CAF9"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Login Form -->
        <Border Grid.Row="1" Background="White" CornerRadius="20 20 0 0" Padding="40">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome Back" FontSize="22" FontWeight="Bold"
                           Foreground="#1A237E" Margin="0,0,0,4"/>
                <TextBlock Text="Please sign in to continue" FontSize="13"
                           Foreground="#78909C" Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Foreground="#546E7A" Margin="0,0,0,4"/>
                <Border BorderBrush="#B0BEC5" BorderThickness="1" CornerRadius="8" Padding="2">
                    <TextBox Text="{Binding UserCode, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="15" Padding="8,6" BorderThickness="0"
                             Background="Transparent"
                             x:Name="TxtUser"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Foreground="#546E7A" Margin="0,20,0,4"/>
                <Border BorderBrush="#B0BEC5" BorderThickness="1" CornerRadius="8" Padding="2">
                    <PasswordBox FontSize="15" Padding="8,6" BorderThickness="0"
                                 Background="Transparent"
                                 x:Name="PwdBox"/>
                </Border>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935"
                           FontSize="12" Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>

                <!-- Login Button -->
                <Button Content="{Binding IsLoading, Converter={StaticResource LoadingTextConverter}, ConverterParameter='Login'}"
                        Command="{Binding LoginCommand}"
                        Background="#1565C0" Foreground="White"
                        FontSize="15" FontWeight="SemiBold"
                        Padding="0,14" Margin="0,24,0,0"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0D47A1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Version -->
                <TextBlock Text="v1.0.0  |  © 2025 Shree Seva Medical" FontSize="10"
                           Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
