<Window x:Class="Medital_Application.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Login – Medical ERP"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0D1B2A">

    <Grid>
        <!-- Two-column layout: left branding panel + right login form -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANEL – Branding ═══ -->
        <Grid Grid.Column="0" Background="#0D1B2A">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Logo circle -->
                <Border Width="110" Height="110" CornerRadius="55"
                        Background="#1565C0" HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#1565C0" BlurRadius="40" ShadowDepth="0" Opacity="0.7"/>
                    </Border.Effect>
                    <TextBlock Text="+" FontSize="64" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="Thin" Margin="0,-8,0,0"/>
                </Border>

                <TextBlock Text="Shree Seva Medical" FontSize="34" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,24,0,6"
                           TextAlignment="Center"/>

                <TextBlock Text="Medical Billing ERP" FontSize="16" Foreground="#90CAF9"
                           HorizontalAlignment="Center" TextAlignment="Center"/>

                <Rectangle Height="2" Width="80" Fill="#1565C0" Margin="0,32,0,32"
                           HorizontalAlignment="Center" Opacity="0.5"/>

                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#546E7A" FontSize="13" LineHeight="24">
                    <Run>GST Billing  •  Stock Management</Run><LineBreak/>
                    <Run>Purchase  •  Accounts  •  Reports</Run>
                </TextBlock>
            </StackPanel>

            <!-- Bottom version text -->
            <TextBlock Text="v1.0.0  |  © 2025 Shree Seva Medical"
                       FontSize="11" Foreground="#37474F"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="0,0,0,24"/>
        </Grid>

        <!-- ═══ RIGHT PANEL – Login Form ═══ -->
        <Border Grid.Column="1" Background="White">
            <Grid>
                <StackPanel VerticalAlignment="Center" Margin="56,0">

                    <TextBlock Text="Welcome Back" FontSize="30" FontWeight="Bold"
                               Foreground="#1A237E" Margin="0,0,0,6"/>
                    <TextBlock Text="Sign in to your account" FontSize="14"
                               Foreground="#78909C" Margin="0,0,0,40"/>

                    <!-- Username -->
                    <TextBlock Text="USERNAME" FontSize="11" Foreground="#546E7A"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border BorderBrush="#CFD8DC" BorderThickness="1.5" CornerRadius="10"
                            Padding="4,2" Margin="0,0,0,24">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Text="{Binding UserCode, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" Padding="10,10" BorderThickness="0"
                                 Background="Transparent" x:Name="TxtUser"/>
                    </Border>

                    <!-- Password -->
                    <TextBlock Text="PASSWORD" FontSize="11" Foreground="#546E7A"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border BorderBrush="#CFD8DC" BorderThickness="1.5" CornerRadius="10"
                            Padding="4,2" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <PasswordBox FontSize="15" Padding="10,10" BorderThickness="0"
                                     Background="Transparent" x:Name="PwdBox"/>
                    </Border>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935"
                               FontSize="12" Margin="4,4,0,16" TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>

                    <!-- Login Button -->
                    <Button Command="{Binding LoginCommand}"
                            Background="#1565C0" Foreground="White"
                            FontSize="15" FontWeight="SemiBold"
                            Padding="0,16" BorderThickness="0" Cursor="Hand">
                        <Button.Content>
                            <TextBlock Text="{Binding IsLoading,
                                Converter={StaticResource LoadingTextConverter},
                                ConverterParameter='Login'}"
                                       HorizontalAlignment="Center"/>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0D47A1"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="Default: ADMIN / admin123" FontSize="11"
                               Foreground="#B0BEC5" HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
